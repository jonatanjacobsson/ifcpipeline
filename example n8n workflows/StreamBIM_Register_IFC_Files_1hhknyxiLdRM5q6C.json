      {
        "id": "be839446-f5d5-4ca6-a630-d21332038e06",
        "name": "Plan registrations",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1940,
          520
        ],
        "parameters": {
          "mode": "runOnceForAllItems",
          "jsCode": "const input = $input.first()?.json ?? {};\nconst projectId = String(input.projectId ?? '13588').trim();\nconst buildingId = String(input.buildingId ?? '1000').trim();\nlet processedFilenames = input.processedFilenames ?? [];\nif (typeof processedFilenames === 'string') {\n  const raw = processedFilenames.trim();\n  if (raw.startsWith('[')) {\n    try { processedFilenames = JSON.parse(raw); } catch { processedFilenames = raw ? [raw] : []; }\n  } else if (raw.includes(',')) {\n    processedFilenames = raw.split(',').map((s) => s.trim()).filter(Boolean);\n  } else {\n    processedFilenames = raw ? [raw] : [];\n  }\n}\nif (!Array.isArray(processedFilenames)) processedFilenames = [];\n\nconst ifcItems = $('Get IFC files').all().map((i) => i.json);\nconst docItems = $('Get IFC documents').all().map((i) => i.json);\n\nconst linkedDocIds = new Set();\nconst existingLayers = new Set();\nconst markedForDeletionDocIds = new Set();\n\nfor (const row of ifcItems) {\n  const id = String(row.id ?? '');\n  const suffix = id.includes('-') ? id.split('-').slice(1).join('-') : id;\n  if (suffix) linkedDocIds.add(suffix);\n  const attrs = row.attributes ?? {};\n  if (attrs['marked-for-deletion'] === true) {\n    markedForDeletionDocIds.add(suffix);\n  }\n  const layerRaw = String(attrs.layer ?? attrs['active-layer'] ?? '').trim();\n  for (const token of layerRaw.split('~')) {\n    const t = token.trim();\n    if (t) existingLayers.add(t);\n  }\n}\n\nfunction extractPrefix(filename) {\n  const base = String(filename ?? '').trim().split(/[\\\\/]/).pop() ?? '';\n  const noExt = base.replace(/\\.ifc$/i, '');\n  const head = noExt.split('_')[0]?.trim();\n  return head ? head.toUpperCase() : '';\n}\n\nfunction scoreLayerMatch(prefix, layer) {\n  const p = prefix.toUpperCase();\n  const l = String(layer ?? '').toUpperCase();\n  if (!p || !l) return 0;\n  if (p === l) return 100;\n  const lHead = l.split('_')[0];\n  if (p === lHead) return 95;\n  if (l.startsWith(p) || p.startsWith(l)) return 80;\n  if (l.includes(p) || p.includes(l)) return 65;\n  return 0;\n}\n\nfunction pickLayer(prefix, layers) {\n  let best = null;\n  let bestScore = 0;\n  for (const layer of layers) {\n    const score = scoreLayerMatch(prefix, layer);\n    if (score > bestScore) {\n      bestScore = score;\n      best = layer;\n    }\n  }\n  if (bestScore >= 65) return { layer: best, reason: 'matched_existing', newLayer: false };\n  return { layer: prefix, reason: 'new_layer_from_prefix', newLayer: true };\n}\n\nconst scope = new Set(\n  processedFilenames.map((n) => String(n).trim().toLowerCase()).filter(Boolean),\n);\nconst useScope = scope.size > 0;\n\nconst details = [];\nconst creates = [];\nconst layersCreated = new Set();\n\nfor (const doc of docItems) {\n  const documentId = String(doc.id ?? '').trim();\n  const filename = String(doc.attributes?.filename ?? doc.attributes?.name ?? documentId).trim();\n  if (!documentId) continue;\n  if (useScope && !scope.has(filename.toLowerCase())) continue;\n  if (linkedDocIds.has(documentId)) continue;\n  if (markedForDeletionDocIds.has(documentId)) {\n    details.push({ documentId, filename, action: 'skip', reason: 'marked_for_deletion' });\n    continue;\n  }\n  const prefix = extractPrefix(filename);\n  if (!prefix) {\n    details.push({ documentId, filename, action: 'skip', reason: 'no_prefix' });\n    continue;\n  }\n  const pick = pickLayer(prefix, [...existingLayers]);\n  if (pick.newLayer) layersCreated.add(pick.layer);\n  existingLayers.add(pick.layer);\n  linkedDocIds.add(documentId);\n  const row = {\n    action: 'create',\n    projectId,\n    buildingId,\n    documentId,\n    filename,\n    layer: pick.layer,\n    reason: pick.reason,\n  };\n  creates.push(row);\n  details.push(row);\n}\n\nif (creates.length === 0) {\n  return [{\n    json: {\n      action: 'summary',\n      skipped: true,\n      registered: 0,\n      skippedCount: details.filter((d) => d.action === 'skip').length,\n      layersCreated: [],\n      details,\n      projectId,\n      buildingId,\n    },\n  }];\n}\n\nreturn creates.map((row) => ({ json: row }));\n"
        }
      },
