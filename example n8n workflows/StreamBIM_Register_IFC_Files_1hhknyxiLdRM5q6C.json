    {
      "id": "88abc390-b0f1-427d-99b5-5539d617b3a4",
      "name": "Create IFC file",
      "type": "CUSTOM.streamBim",
      "typeVersion": 8,
      "position": [
        2380,
        440
      ],
      "parameters": {
        "resource": "ifcFile",
        "projectId": "={{ $json.projectId }}",
        "buildingId": "={{ $json.buildingId }}",
        "documentId": "={{ $json.documentId }}",
        "layer": "={{ $json.layer }}",
        "markedForDeletion": false,
        "operation": "create"
      },
      "credentials": {
        "streamBimApi": {
          "id": "v1oA21A76m4mWYvK",
          "name": "StreamBIM app account"
        }
      }
    },
    {
      "id": "0554fcae-53ff-4a8f-b27e-c39d7b334829",
      "name": "Build summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2600,
        520
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const planned = $('Plan registrations').all().map((i) => i.json);\nif (planned.length === 1 && planned[0].action === 'summary') {\n  return [{ json: planned[0] }];\n}\nconst timeout = $('Sync timeout summary').all().map((i) => i.json)[0];\nif (timeout?.action === 'summary') {\n  return [{ json: timeout }];\n}\nconst created = $('Create IFC file').all().map((i) => i.json);\nconst creates = planned.filter((p) => p.action === 'create');\nconst layersCreated = [...new Set(creates.filter((p) => p.reason === 'new_layer_from_prefix').map((p) => p.layer))];\nconst details = planned.map((p) => {\n  if (p.action !== 'create') return p;\n  const ok = created.some((c) => String(c.id ?? '').endsWith(`-${p.documentId}`) || String(c.id ?? '') === `${p.buildingId}-${p.documentId}`);\n  return { ...p, action: ok ? 'created' : 'create_failed' };\n});\nreturn [{\n  json: {\n    action: 'summary',\n    skipped: false,\n    registered: creates.length,\n    skippedCount: planned.filter((p) => p.action === 'skip').length,\n    layersCreated,\n    details,\n  },\n}];\n"
      }
    }
