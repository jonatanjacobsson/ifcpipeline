    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const j = $input.first().json;\nconst batch_file = $('Pass Job ID').item.json.batch_file;\nlet ok = false;\nif (j.error) ok = false;\nelse if (j.status === 'failed') ok = false;\nelse if (j.status === 'finished' && j.result && j.result.success !== false) ok = true;\nreturn [{ json: { ...j, batch_file, ok } }];"
