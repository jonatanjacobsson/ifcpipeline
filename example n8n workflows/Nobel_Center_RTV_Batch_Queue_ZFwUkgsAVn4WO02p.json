C:\\\\Users\\\\Nattugglan\\\\Nobel Center\\\\Syncpoint - General\\\\Pipeline\\\\RTV Config\\\\Batch\\\\S2-Batch - PDF.rbxml',\n  'C:\\\\Users\\\\Nattugglan\\\\Nobel Center\\\\Syncpoint - General\\\\Pipeline\\\\RTV Config\\\\Batch\\\\S2-Batch.rbxml'\n];\nconst testOnly = base.test_only === true || base.test_only === 'true';\nconst list = testOnly ? paths.slice(0, 1) : paths;\nreturn list.map((batch_file) => ({ json: { ...base, batch_file } }));"
