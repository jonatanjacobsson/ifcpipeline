    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const raw = $input.item.json;\nconst ctx = $getWorkflowStaticData('global').jobWaitCtx || {};\nconst status = raw.status || (raw.error ? 'failed' : undefined);\nconst err = raw.error ?? raw.message ?? null;\nreturn {\n  json: {\n    ...ctx,\n    status,\n    result: raw.result ?? null,\n    error: err,\n  },\n};\n"
      },
