    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item.json;\nconst msg = String(item.error || item.message || 'Unknown error');\nconst RETRYABLE = [/Work-horse terminated/i,/waitpid returned/i,/signal \\d+/i,/timeout/i,/timed out/i,/ConnectionError/i,/MemoryError/i,/ENOMEM/i,/Temporary failure/i,/isolation strategies exhausted/i,/kernel failure/i,/Broken pipe/i,/child.*exit/i];\nconst NON_RETRYABLE = [/VisitError/i,/SyntaxError/i,/JSONDecodeError/i,/Invalid.*selector/i,/KeyError/i,/ValueError/i,/FileNotFoundError/i,/No such file/i,/Recipe.*not found/i,/Invalid JSON/i];\nfunction isRetryable(m) {\n  if (RETRYABLE.some(p => p.test(m))) return true;\n  if (NON_RETRYABLE.some(p => p.test(m))) return false;\n  return true;\n}\nconst retryable = isRetryable(msg);\nconst attempt = Number(item.attempt ?? 0);\nconst maxRetries = Number(item.max_retries ?? 3);\nconst canRetry = retryable && attempt < maxRetries;\nconst out = { ...item, retryable, can_retry: canRetry, error_message: msg };\n$getWorkflowStaticData('global').jobWaitCtx = out;\nreturn { json: out };\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2240,
        256
      ],
