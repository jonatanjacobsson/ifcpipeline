      ]
    },
    "Upload IFC → MinIO": {
      "main": [
        [{"node": "Merge uploaded keys", "type": "main", "index": 0}]
      ]
    },
    "Upload IDS → MinIO": {
      "main": [
        [{"node": "Merge uploaded keys", "type": "main", "index": 1}]
      ]
    },
    "Merge uploaded keys": {
      "main": [
        [{"node": "Pick storage refs", "type": "main", "index": 0}]
      ]
    },
    "Pick storage refs": {
      "main": [
        [
          {"node": "IfcCsv: walls → CSV", "type": "main", "index": 0},
          {"node": "IfcTester: validate", "type": "main", "index": 0},
          {"node": "IfcToJson: to JSON", "type": "main", "index": 0}
        ]
