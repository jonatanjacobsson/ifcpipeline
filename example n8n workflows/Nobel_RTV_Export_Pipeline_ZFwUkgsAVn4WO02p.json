      "parameters": {
        "jsCode": "// Nobel RTV Export - Batch Job Preparation\n// Config\nconst allBatches = [\"PL\", \"S2\", \"SP1\", \"E1\", \"LA\", \"MEP\"];\nconst batchBasePath = \"C:\\\\Users\\\\Nattugglan\\\\Nobel Center\\\\Syncpoint - General\\\\Pipeline\\\\RTV Config\\\\Batch\";\nconst scriptPath = \"C:\\\\revit-worker\\\\scripts\\\\Run-RTVXporterBatch.ps1\";\nconst timeout = 7200;\n\n// If webhook provided specific batches, use those; otherwise export all\nconst input = $input.first().json;\nconst requestedBatches = input?.body?.batches;\nconst batches = (Array.isArray(requestedBatches) && requestedBatches.length > 0)\n  ? requestedBatches.filter(b => allBatches.includes(b))\n  : allBatches;\n\nreturn batches.map(prefix => ({\n  json: {\n    prefix,\n    batch_file: `${batchBasePath}\\\\${prefix}-Batch.rbxml`,\n    script_path: scriptPath,\n    timeout_seconds: timeout\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        288,
        448
      ],
