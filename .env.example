# API Gateway security
# Generate a new UUID for this value or use another secure random string
# IMPORTANT: Set this to authorize API requests via Swagger UI at http://localhost:8000/docs
# Click "Authorize" button and enter this API key
IFC_PIPELINE_API_KEY=change-me-to-a-secure-random-string

# Comma-separated list of allowed IP ranges in CIDR notation
# IPs in these ranges can bypass API key authentication
IFC_PIPELINE_ALLOWED_IP_RANGES=127.0.0.1/32,172.18.0.0/16
# Docker bridge gateway IP - external traffic arrives via this; never whitelisted (comma-separated for multiple)
DOCKER_GATEWAY_IP=172.18.0.1
IFC_PIPELINE_EXTERNAL_URL=https://ifcpipeline.example.com
IFC_PIPELINE_PREVIEW_EXTERNAL_URL=https://ifcpreview.example.com

# n8n configuration
# Replace with your actual n8n webhook URL
N8N_WEBHOOK_URL=https://your-n8n-instance.example.com

# Community nodes
# Set to true to enable community nodes
N8N_COMMUNITY_PACKAGES_ENABLED=true

# PostgreSQL Configuration
POSTGRES_USER=ifcpipeline
POSTGRES_PASSWORD=change-me-to-a-secure-password
POSTGRES_DB=ifcpipeline
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Remote workers on a second Hyper-V VM (see REMOTE_WORKERS.md)
# PIPELINE_LAN_IP=172.17.94.40
# WORKER_VM_IP=172.17.91.108
# PIPELINE_HOST=primary-host

# Redis Configuration (internal use only - not exposed to public internet)
# Note: Redis 7.2.11+ is used to address CVE-2025-49844
# Keep Redis port internal - do not expose 6379 to public internet
REDIS_URL=redis://redis:6379/0

# IMPORTANT NOTES:
# 1. Queue Status: On first run, queues will show "waiting (no jobs yet)" - this is normal
# 2. API Key: Required for all API endpoints unless IP is in allowed ranges
# 3. Sample Files: Example IFC files available in /shared/examples/ directory
# 4. Redis Security: Keep Redis internal only (port 6379 should not be publicly accessible)

# ---------------------------------------------------------------------------
# SeaweedFS dual-write pilot (off when empty)
# ---------------------------------------------------------------------------
# See SEAWEEDFS_PILOT.md (dual-write pilot) and SEAWEEDFS_CUTOVER.md (migration).
#
# When S3_SHADOW_ENDPOINT_URL is empty (default), shared/object_storage.py
# behaves exactly like the MinIO-only stack. When set, every successful PUT
# in upload_from_path / upload_fileobj_and_hash / upload_and_audit also
# writes to the shadow backend on a best-effort basis (failures are logged
# + counted, never raised) and stashes shadow_version_id in
# object_versions.metadata.
#
# Bring-up:
#   docker compose -f docker-compose.yml -f docker-compose.seaweedfs.yml \
#     --profile seaweedfs-pilot up -d
#
# Kill switch: set S3_SHADOW_ENDPOINT_URL= (empty) and recreate the
# production services.
#
# IMPORTANT: S3_SHADOW_ACCESS_KEY / S3_SHADOW_SECRET_KEY must match the
# `accessKey` / `secretKey` in seaweedfs/s3.json. Rotate both at once.
S3_SHADOW_ENDPOINT_URL=http://seaweedfs:8333
S3_SHADOW_ACCESS_KEY=seaweedfs-pilot
S3_SHADOW_SECRET_KEY=change-me-to-a-secure-password
S3_SHADOW_BUCKET=ifcpipeline
S3_SHADOW_REGION=us-east-1

# Parity / smoke tunables (optional).
# PARITY_INTERVAL_S=600        # seconds between parity ticks
# PARITY_SAMPLE_N=20           # shared keys to HEAD-sample per tick
# PARITY_MAX_LIST=50000        # cap on listed keys per backend per tick
# SMOKE_INTERVAL_S=86400       # seconds between daily-smoke runs
# SMOKE_LIFECYCLE_WAIT_S=1800  # max wait for non-current version expiry
# SMOKE_LIFECYCLE_POLL_S=60    # poll interval inside the smoke wait loop

# ---------------------------------------------------------------------------
# Baserow (BIP001 Gherkin — ifc-gherkin-worker)
# ---------------------------------------------------------------------------
# docker-compose mounts optional ../cde/.env on the worker; if present, CDE_BASEROW_API_BASE,
# CDE_BASEROW_API_KEY, and CDE_BASEROW_IDS_PROPERTIES_TABLE_ID are picked up automatically
# (see shared/baserow_bip_type_defining.py). To override without cde/.env, set either pair:
#   BASEROW_API_BASE=...   BASEROW_API_TOKEN=...
# or the same names CDE uses:
#   CDE_BASEROW_API_BASE=https://your-baserow.example.com/api
#   CDE_BASEROW_API_KEY=your-database-token
#   CDE_BASEROW_IDS_PROPERTIES_TABLE_ID=1234