+// upstream-u2 (Phase 10): mutex-protect the lazy schema cache.  The
+// original DCL-without-lock pattern is unsafe when multiple threads or
+// reentrant calls hit get_schema() before populate completes.  A
+// function-local C++11 magic-static would be cleanest, but clear_schema()
+// needs to drop the cache, so we keep the file-scope unique_ptr and gate
+// it on a file-scope std::mutex.  See HUNT_REPORT Phase 10 for context.
+static std::mutex schema_mtx;
 static std::unique_ptr<schema_definition> schema;
 
 void Ifc4x1::clear_schema() {
+    std::lock_guard<std::mutex> lk(schema_mtx);
     schema.reset();
 }
 
 const schema_definition& Ifc4x1::get_schema() {
+    std::lock_guard<std::mutex> lk(schema_mtx);
     if (!schema) {
         schema.reset(IFC4X1_populate_schema());
     }
