# Remote worker env (worker host). Copy to .env.remote on the worker host.
# Or let scripts/deploy-remote-workers-from-primary.sh generate it from primary .env.
#
# Primary stack hostname (used for logs; prefer LAN IP for TCP):
PIPELINE_HOST=primary-host

# LAN IP of the primary host on the route to the worker (run on primary: ./scripts/detect-pipeline-lan-ip.sh)
PIPELINE_LAN_IP=10.0.0.1

# Broker + data plane (use PIPELINE_LAN_IP — hostname alone fails if DNS/mDNS is stale)
REDIS_URL=redis://10.0.0.1:6379/0
POSTGRES_HOST=10.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=ifcpipeline
POSTGRES_USER=ifcpipeline
POSTGRES_PASSWORD=change-me-copy-from-primary-.env

USE_OBJECT_STORAGE=true
# Object store is SeaweedFS S3 on the primary host, published on the LAN at
# PIPELINE_LAN_IP:8333 by docker-compose.host-lan.yml (MinIO was decommissioned
# 2026-06). Keys must match the primary .env S3_ACCESS_KEY/S3_SECRET_KEY
# (and seaweedfs/s3.json).
S3_ENDPOINT_URL=http://10.0.0.1:8333
S3_ACCESS_KEY=change-me-copy-from-primary-.env
S3_SECRET_KEY=change-me-copy-from-primary-.env
S3_BUCKET=ifcpipeline
S3_REGION=us-east-1
S3_CHECKSUM_MODE=app

LOG_LEVEL=INFO

# Worker counts on this host (--scale; RAM must fit sum of limits per replica)
IFCTESTER_REMOTE_REPLICAS=1
IFCPATCH_REMOTE_REPLICAS=2
IFCCLASH_REMOTE_REPLICAS=1
IFCDIFF_REMOTE_REPLICAS=1

# ifcpatch (optional — copy tuning from primary .env)
IFCPATCH_DEBUG=0
IFCPATCH_CORE_LIMIT=0

# ifcclash (optional — copy tuning from primary .env)
IFCCLASH_GEOMETRY_LIBRARY=cgal
IFCCLASH_ITERATOR_THREADS=4
IFCCLASH_ISOLATE=1
IFCCLASH_BVH_CACHE=off
IFCCLASH_BVH_CACHE_DIR=/tmp/ifcclash-bvh-cache
IFCCLASH_BVH_CACHE_MAX_MB=4096
IFCCLASH_BVH_CACHE_MINIO_PREFIX=cache/clash-tess
IFCCLASH_VALIDATE_CACHE=on
IFCCLASH_VALIDATE_CACHE_TTL_S=604800
IFCCLASH_VALIDATE_CACHE_PREFIX=ifcclash:validate

# NOTE: the legacy SeaweedFS dual-write shadow vars (S3_SHADOW_*) are obsolete
# now that SeaweedFS is the sole object store. Do not set them.
