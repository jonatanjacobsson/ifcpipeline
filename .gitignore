# ifcpipeline/.gitignore
#
# Tier 1 (track by default): source, tests, docs/*.md, docs/, ifc-coord/research/,
#   example n8n exports, .cursor/rules + .cursor/skills, mapping *.example.py
# Tier 2 (below): regenerable artifacts, secrets, large binaries, client data

# --- Secrets & local config -----------------------------------------
.env
.env.*
!.env.example
!.env.*.example
api-gateway/config.json
ifc-pipeline.code-workspace
seaweedfs/s3.json
!seaweedfs/s3.json.example

# --- Runtime / job I/O (large; not reproducible from git) ------------
shared/uploads/*
shared/output/*/*
prod-fixtures/
/n8n-data/*
!n8n-data/.gitkeep
/tfmgen/*

# --- Regenerable eval & hunt artifacts ------------------------------
# Durable write-ups live at repo root: HUNT_REPORT_*.md, IFCOPENSHELL_*.md
hunt-evidence/
parity-reports/

reports/

# --- Live n8n instance (use example n8n workflows/ for exports) -----
n8n-workflows/*

# --- Client / project-specific mapping tables -----------------------
# See ifcpatch-worker/custom_recipes/mappings/README.md
ifcpatch-worker/custom_recipes/mappings/nobel_a1_*.py
!ifcpatch-worker/custom_recipes/mappings/nobel_a1_*.example.py

# --- One-off Cursor helpers (keep .cursor/rules and .cursor/skills) -
.cursor/*.py
.cursor/debug-*.log

# --- Build & toolchain ----------------------------------------------
bin/
obj/
publish/
revit-worker/RevitWorkerApp.exe
__pycache__/
*.pyc
venv/
.pytest_cache/

# --- IDE & OS -------------------------------------------------------
.vscode/
.idea/
digitalocean*
.DS_Store
Thumbs.db

# Ignore n8n data folders
/n8n-data/*
!n8n-data/.gitkeep

# Ignore tfmgen data folders
/tfmgen/*

# Ignore api-gateway config
api-gateway/config.json

# Uncomment the line above if you want to ignore the config file
# Make sure to use a template or example config file for version control

# Environment variables
.env
ifc-pipeline.code-workspace
prod-fixtures/

# One-off DB / migration helper scripts (keep .cursor/rules and .cursor/skills tracked)
.cursor/*.py
.cursor/debug-*.log

# One-off patch/helper scripts at repo root
/patch_*.py

# Generated workflows, reports, and evidence/logs - not meant for git
/n8n-workflows/
/reports/
/parity-reports/
/hunt-evidence/

# Large MagiCAD IFC test fixtures - not meant for git
ifcpatch-worker/tests/fixtures/magicad/*.ifc

# Build/egg metadata
shared/shared.egg-info/
shared/output/debug-*.log

# --- Always keep empty-dir placeholders -----------------------------
!**/.gitkeep
