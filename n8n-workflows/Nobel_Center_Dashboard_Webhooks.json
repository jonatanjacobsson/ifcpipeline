      "name": "Return clash data"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH latest_rows AS (\n  SELECT DISTINCT ON (clash_set_name) id, clash_set_name, created_at, clash_data\n  FROM clash_results WHERE lower(clash_set_name) NOT LIKE '%test%'\n  ORDER BY clash_set_name, created_at DESC\n),\nlast_week_rows AS (\n  SELECT DISTINCT ON (clash_set_name) id, clash_set_name, created_at, clash_data\n  FROM clash_results\n  WHERE created_at BETWEEN (NOW() - INTERVAL '7 days') AND NOW()\n    AND lower(clash_set_name) NOT LIKE '%test%'\n  ORDER BY clash_set_name, created_at ASC\n),\nlatest_counts AS (\n  SELECT lr.id, lr.clash_set_name, lr.created_at,\n    (SELECT COUNT(DISTINCT (clash->>'smart_group'))\n     FROM jsonb_array_elements(lr.clash_data) cs, jsonb_each(cs->'clashes') AS ce(k, clash)\n     WHERE clash->>'smart_group' IS NOT NULL)::int AS unique_smart_groups,\n    regexp_replace(lr.clash_data->0->'a'->0->>'file', '^.*/', '') AS model_a_file,\n    regexp_replace(lr.clash_data->0->'b'->0->>'file', '^.*/', '') AS model_b_file\n  FROM latest_rows lr\n),\nlast_week_counts AS (\n  SELECT lw.id, lw.clash_set_name, lw.created_at,\n    (SELECT COUNT(DISTINCT (clash->>'smart_group'))\n     FROM jsonb_array_elements(lw.clash_data) cs, jsonb_each(cs->'clashes') AS ce(k, clash)\n     WHERE clash->>'smart_group' IS NOT NULL)::int AS unique_smart_groups\n  FROM last_week_rows lw\n),\nresults_json AS (\n  SELECT json_build_object(\n    'data', COALESCE((\n      SELECT json_agg(result_row) FROM (\n        SELECT lr.clash_set_name as clash_set,\n          split_part(lr.clash_set_name, ' vs ', 1) as model_a,\n          split_part(lr.clash_set_name, ' vs ', 2) as model_b,\n          lr.unique_smart_groups as clash_groups,\n          COALESCE(lr.unique_smart_groups - lw.unique_smart_groups, 0) as clash_groups_change,\n          lr.model_a_file, lr.model_b_file\n        FROM latest_counts lr\n        LEFT JOIN last_week_counts lw ON lr.clash_set_name = lw.clash_set_name\n        ORDER BY lr.clash_set_name\n      ) as result_row\n    ), '[]'::json),\n    'date', (SELECT to_char(MAX(created_at), 'YYYY-MM-DD\"T\"HH24:MI:SS.MS\"Z\"') FROM latest_counts),\n    'last_week_date', (SELECT to_char(MIN(created_at), 'YYYY-MM-DD\"T\"HH24:MI:SS.MS\"Z\"') FROM last_week_counts)\n  ) as result\n)\nSELECT result FROM results_json;",
        "options": {}
      },
