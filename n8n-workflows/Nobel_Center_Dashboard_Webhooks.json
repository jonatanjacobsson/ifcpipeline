    {
      "id": "76df2e60-cdbb-486e-a885-7fbe2305d4a6",
      "name": "Clash Groups Endpoint",
      "type": "n8n-nodes-base.webhook",
      "position": [
        960,
        848
      ],
      "webhookId": "039ed992-478c-4737-9100-45b4c1a274a3",
      "parameters": {
        "path": "bimhealth/nobel/clash-groups",
        "options": {
          "allowedOrigins": "https://c23b70d8-3d96-4f36-ab8c-dab207d8997c.lovableproject.com,https://id-preview--c23b70d8-3d96-4f36-ab8c-dab207d8997c.lovable.app,https://nobelpipelinedashboard.lovable.app,https://nobelpipelinedashboard.byggstyrning.se,https://nobelhub.byggstyrning.se,http://localhost:8080,http://localhost:5173"
        },
        "responseMode": "responseNode"
      },
      "typeVersion": 2
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, clash_set_name, clash_count, clash_data\nFROM clash_results\nWHERE original_clash_id IS NULL\n  AND clash_set_name ILIKE '%' || $1::text || '%'\n  AND clash_set_name ILIKE '%' || $2::text || '%'\nORDER BY created_at DESC\nLIMIT 1",
        "options": {
          "queryReplacement": "={{ $json.query.model_a }},{{ $json.query.model_b }}"
        }
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1184,
        848
      ],
      "id": "b89934be-eb91-453d-a25e-659c74209fc1",
      "name": "Fetch clash row for pair",
      "credentials": {
        "postgres": {
          "id": "DayfeOedf7i7XWk2",
          "name": "ifcpipeline postgress"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const req = $('Clash Groups Endpoint').first().json;\nconst ma = String(req.query?.model_a ?? '').trim();\nconst mb = String(req.query?.model_b ?? '').trim();\nconst slug = [ma, mb].filter(Boolean).join('-') || 'unknown';\n\nconst row = $input.first().json;\nconst hasData = row && row.clash_data != null;\n\nif (!hasData) {\n  return [{ json: { _status: 404, error: 'not_found',\n    message: 'No clash result for this model pair', clash_set: slug } }];\n}\n\nlet data = row.clash_data;\nif (typeof data === 'string') data = JSON.parse(data);\nif (!Array.isArray(data)) data = [data];\n\n// Find the matching clash set\nlet cs = data.find(s => {\n  const n = (s.name || '').toLowerCase();\n  return n.includes(ma.toLowerCase()) && n.includes(mb.toLowerCase());\n}) || data[0];\n\nif (!cs) {\n  return [{ json: { _status: 404, error: 'not_found',\n    clash_set: slug, message: 'No matching set in clash_data' } }];\n}\n\nconst pickFile = (arr) => (Array.isArray(arr) && arr[0] && arr[0].file ? String(arr[0].file).split('/').pop() : null);\nconst model_a_file = pickFile(cs.a);\nconst model_b_file = pickFile(cs.b);\nconst clashes = cs.clashes || {};\nconst groups = new Map();\n\nfor (const [cid, c] of Object.entries(clashes)) {\n  const sg = c.smart_group;\n  const gk = sg != null ? `cg-${sg}` : `cg-${cid}`;\n  if (!groups.has(gk)) {\n    groups.set(gk, { id: gk,\n      name: sg != null ? `Smart group ${sg}` : `Clash ${cid}`,\n      count: 0, change: 0, guids_a: [], guids_b: [], center_guid: null });\n  }\n  const g = groups.get(gk);\n  g.count++;\n  if (c.a_global_id) {\n    g.guids_a.push(c.a_global_id);\n    if (!g.center_guid) g.center_guid = c.a_global_id;\n  }\n  if (c.b_global_id) g.guids_b.push(c.b_global_id);\n}\n\nfor (const g of groups.values()) {\n  g.guids_a = [...new Set(g.guids_a)];\n  g.guids_b = [...new Set(g.guids_b)];\n}\n\nreturn [{ json: { _status: 200,\n  clash_set: slug, model_a_file, model_b_file, groups: [...groups.values()] } }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1408,
        848
      ],
      "id": "bd7ddfeb-a8f7-4bb8-b9d5-b69eff1a55ad",
      "name": "Build clash groups JSON"
    },
