      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json._status === 200 ? { clash_set: $json.clash_set, groups: $json.groups } : { error: $json.error, message: $json.message, clash_set: $json.clash_set } }}",
        "options": {
          "responseCode": "={{ $json._status || 200 }}"
        }
      },
