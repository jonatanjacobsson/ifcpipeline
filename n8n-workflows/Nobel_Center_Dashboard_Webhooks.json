    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT name,\n       added_count,\n       updated_count,\n       deleted_count,\n       total_changes,\n       checked_at\nFROM (\n    SELECT\n        REPLACE(new_file, '/uploads/', '') AS name,\n        COALESCE(jsonb_array_length(diff_data->'added'), 0)::int AS added_count,\n        (SELECT COUNT(*) FROM jsonb_object_keys(diff_data->'changed'))::int AS updated_count,\n        COALESCE(jsonb_array_length(diff_data->'deleted'), 0)::int AS deleted_count,\n        (\n            COALESCE(jsonb_array_length(diff_data->'added'), 0)::int\n          + (SELECT COUNT(*) FROM jsonb_object_keys(diff_data->'changed'))::int\n          + COALESCE(jsonb_array_length(diff_data->'deleted'), 0)::int\n        ) AS total_changes,\n        created_at AS checked_at,\n        ROW_NUMBER() OVER (\n            PARTITION BY REPLACE(new_file, '/uploads/', '')\n            ORDER BY created_at DESC\n        ) AS rn\n    FROM diff_results\n) AS sub\nWHERE rn = 1\nORDER BY checked_at DESC;\n",
        "options": {}
      },
